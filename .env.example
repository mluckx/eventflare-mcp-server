# Eventflare MCP Server v2 — environment variables
# Copy to .env and fill in. Never commit .env.

# ─── Required ─────────────────────────────────────────────
EVENTFLARE_API_TOKEN=eyJhbGciOi...   # Strapi API token, mcp-readonly role

# ─── Optional ─────────────────────────────────────────────
EVENTFLARE_API_URL=https://content.eventflare.io/api   # production default
EVENTFLARE_URL=https://eventflare.io                   # for outbound URLs
TRANSPORT=stdio                                        # 'stdio' or 'http'
PORT=3001                                              # HTTP port
RATE_LIMIT=60                                          # per-IP requests per minute
DASHBOARD_KEY=                                         # if set, /dashboard requires ?key=...

# ─── Analytics sink (pick ONE — or leave both unset for local-only) ──────
# Option A: OpenPanel (recommended — set both)
OPENPANEL_CLIENT_ID=
OPENPANEL_CLIENT_SECRET=
OPENPANEL_API_URL=https://api.openpanel.dev

# Option B: Generic webhook (POST per event)
ANALYTICS_SINK_URL=
ANALYTICS_SINK_TOKEN=

# ─── Local logs ───────────────────────────────────────────
LOG_DIR=./logs
